model DefaultProjectTargetLanguage {
	projectId	String	@map("project_id")
	language	String	@map("language_code") @db.Char(2)

	project		Project	@relation("DefaultTargetLanguages", fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

	@@id([projectId, language])
	@@map("default_project_target_languages")
}

model Project {
	id				String	@id @default(cuid())
	slug			String	@unique
	title			String
	description		String?
	imageUrl		String?

	publicVisible	Boolean	@default(false)
	publicJoin		Boolean	@default(false)
	publicDownload	Boolean	@default(false)

	defaultSourceLanguage	String	@map("default_source_language_code") @db.Char(2)
	defaultTargetLanguages	DefaultProjectTargetLanguage[] @relation("DefaultTargetLanguages")

	labels			Labels[]

	createdAt		DateTime	@default(now())	@map("created_at")
	updatedAt		DateTime	@updatedAt		@map("updated_at")

	sourceFiles		SourceFile[]
	members			ProjectMember[]
	apiKeys			ProjectApiKey[]

	@@map("projects")
}



enum ProjectRole {
	BANNED		// No access to the project, can't rejoin
	TRANSLATOR  // Can translate and suggest new locale strings
	REVIEWER	// Can review and approve translations
	MODERATOR	// Can manage users, labels, delete translations, delete comments
	ADMIN		// Full access to all project features
	OWNER		// Full access including managing project settings and deleting the project
}


model ProjectMember {
	projectId	String		@map("project_id")
	userId		String		@map("user_id")
	role		ProjectRole	@map("role")

	createdAt		DateTime	@default(now())	@map("created_at")
	updatedAt		DateTime	@updatedAt		@map("updated_at")

	project			Project	@relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
	user			User	@relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

	@@id([projectId, userId])
	@@map("project_members")
}

enum ProjectApiKeyAccess {
	READ_ONLY
	READ_WRITE
}

model ProjectApiKey {
	id			String	@id @default(cuid())
	projectId	String	@map("project_id")
	key			String	@unique

	access		ProjectApiKeyAccess	@map("access")

	createdAt	DateTime	@default(now())	@map("created_at")
	updatedAt	DateTime	@updatedAt		@map("updated_at")

	project		Project	@relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
	@@map("project_api_keys")
}
