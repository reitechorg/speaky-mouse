model Labels {
	id			String		@id @default(cuid())
	projectId	String		@map("project_id")
	name		String
	color		String

	project			Project	@relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
	localeStrings	LocaleString[]	@relation("LocaleStringLabels")

	@@map("labels")
}

enum NotTranslatedExportMode {
	KEEP_ORIGINAL	// Keep the original string from the source language
	EMPTY_STRING	// Export an empty string
	SKIP_STRING		// Do not include the string in the export
	FAIL_EXPORT		// Fail the export process
}

model SourceFile {
	id			String		@id @default(cuid())
	title		String

	importPath	String		@map("import_path")
	exportPath  String		@map("export_path")
	parser		String?

	projectId	String		@map("project_id")
	project		Project		@relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

	sourceLanguage	String	@map("source_language_code") @db.Char(2)
	targetLanguages	SourceFileTargetLanguage[]
	localeStrings	LocaleString[]

	notTranslatedStringExportMode	NotTranslatedExportMode	@map("export_not_translated")	@default(KEEP_ORIGINAL)

	@@map("source_files")
}

model SourceFileTargetLanguage {
	sourceFileId	String	@map("source_file_id")
	language		String	@map("language_code") @db.Char(2)

	sourceFile		SourceFile	@relation(fields: [sourceFileId], references: [id], onDelete: Cascade, onUpdate: Cascade)

	@@id([sourceFileId, language])
	@@map("source_file_target_languages")
}

model LocaleString {
	id				String				@id @default(cuid())
	key				String
	content			String
	maxLength		Int?				@map("max_length")
	sourceFileId	String				@map("source_file_id")

	labels			Labels[]		@relation("LocaleStringLabels")
	sourceFile		SourceFile		@relation(fields: [sourceFileId], references: [id], onUpdate: Cascade, onDelete: Cascade)
	translations	Translation[]

	@@map("locale_strings")
}

model Translation {
	id				String				@id @default(cuid())
	localeStringId	String				@map("locale_string_id")
	language		String				@map("language_code") @db.Char(2)
	content			String
	authorId		String				@map("author_id")
	createdAt		DateTime			@map("created_at") @default(now())
	updatedAt		DateTime			@map("updated_at") @updatedAt
	approvedBy		String?				@map("approved_by")
	approvedAt		DateTime?			@map("approved_at")

	author			User				@relation("TranslationAuthor", fields: [authorId], references: [id])
	approver		User?				@relation("TranslationApprover", fields: [approvedBy], references: [id])
	localeString	LocaleString		@relation(fields: [localeStringId], references: [id], onUpdate: Cascade, onDelete: Cascade)


	@@map("translated_strings")
}
