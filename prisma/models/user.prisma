enum SystemRole {
	BANNED
	BOT
	USER
	ADMIN
}

model User {
	id				String		@id @default(cuid())
	email			String		@unique
	name			String
	passwordHash	String?		@map("password_hash")
	realmOfOrigin	String?		@map("realm_of_origin")

	createdAt		DateTime	@default(now())	@map("created_at")
	updatedAt		DateTime	@updatedAt		@map("updated_at")
	deletedAt		DateTime?	@map("deleted_at")
	systemRole		SystemRole	@default(USER)	@map("system_role")

	translationsAuthored	Translation[]	@relation("TranslationAuthor")
	translationsApproved	Translation[]	@relation("TranslationApprover")

	memberships		ProjectMember[]

	@@map("users")
}
