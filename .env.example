DATABASE_URL="mysql://root:root@localhost:3306/speaky_mouse"
AUTH_SECRET="..." # Run `npx auth secret` to generate. Read more: https://cli.authjs.dev

# +----[ Auth settings ]----
#
# If set to true, disables email/password login
# DISABLE_PASSWORD_LOGIN=false
#
# Comma-separated list of allowed origins for cross-origin requests.
# Add your production URL here (e.g. https://your.speaky-mouse.instance.com).
# Defaults to http://localhost:3000 when unset.
# AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://your.domain.com

# +----[ Skip login page - use specific provider ]----
# | If you don't want to show users the login page and want to
# | force them to login via a specific provider, you can disable
# | the login page by setting DISABLE_PASSWORD_LOGIN to true and
# | configuring only one OAuth provider.

# +----[ Integrated OAuth Providers ]----
# | We provide integration with most BetterAuth supported OAuth providers
# | You can enable as many as you want by adding the respective keys/secrets below.
# | Better auth providers: https://www.better-auth.com/docs/authentication/email-password
# +----------------------------
# Required format:
# AUTH_<provider>_ID=
# AUTH_<provider>_SECRET=
#
# Example for GitHub:
# AUTH_GITHUB_ID="your_github_client_id"
# AUTH_GITHUB_SECRET="your_github_client_secret"


# +----[ Custom OAuth Providers ]----
# You can define your own custom OAuth providers by listing them in the
# AUTH_CUSTOM_PROVIDERS variable (comma-separated)
#
# Example:
# AUTH_CUSTOM_PROVIDERS="customprovider, anotherprovider"
#
# Then you can define the settings for each custom provider
# using the following variables.
# Replace <provider> with the name of your provider in uppercase. (e.g. for "customprovider" use "AUTH_<provider>_ID" -> "AUTH_CUSTOMPROVIDER_ID")
#
# AUTH_<provider>_ID=                     # Client ID - required
# AUTH_<provider>_SECRET=                 # Client Secret - required
# AUTH_<provider>_REDIRECT_URI=           # Redirect URI - required - should be set to https://your.speaky-mouse.instance.com/api/auth/oauth2/callback/<provider>
# AUTH_<provider>_DISCOVERY_URL=          # URL to the OpenID Connect discovery document - Optional but if not specified you need to provide the below URLs manually
# AUTH_<provider>_AUTHORIZATION_URL=      # Authorization URL - required if no discovery URL
# AUTH_<provider>_TOKEN_URL=              # Token URL - required if no discovery URL
# AUTH_<provider>_USERINFO_URL=           # Userinfo URL - required if no discovery URL
# AUTH_<provider>_SCOPES=                 # Scopes (comma-separated)
# AUTH_<provider>_RESPONSE_MODE           # Response mode ("query" or "form_post") - optional - default is query
# AUTH_<provider>_DISABLE_IMPLICIT_SIGNUP # Optional - default is false
# AUTH_<provider>_DISABLE_SIGNUP          # Optional - default is false
# AUTH_<provider>_ACCESS_TYPE=            # Optional
# AUTH_<provider>_PROMPT=                 # Optional - "none", "login", "consent", "select_account"
# AUTH_<provider>_RESPONSE_TYPE=          # Optional - default is "code"
# AUTH_<provider>_PKCE=                   # Optional - default is false
#
# If mapping of profile is not working correctly, you can specify the mapping explicitly:
# AUTH_<provider>_MAP_NAME=               # Optional - profile field to map to user name - tries to detect automatically if not set
# AUTH_<provider>_MAP_EMAIL=              # Optional - profile field to map to user email - tries to detect automatically if not set
# AUTH_<provider>_MAP_EMAIL_VERIFIED=     # Optional - profile field to map to user email verified - tries to detect automatically if not set
# AUTH_<provider>_MAP_IMAGE=              # Optional - profile field to map to user image - tries to detect automatically if not set
# AUTH_<provider>_MAP_ROLE=               # Optional - profile field to map to user role - default is "user" if not set
#
# You can also customize the login screen appearance:
# AUTH_<provider>_TITLE                   # Optional - Custom title for the provider on login screen
# AUTH_<provider>_ICON_URL                # Optional - Custom icon URL for the provider on login screen
